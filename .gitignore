# Claude Code session state. Carve out settings.json so the
# team-shared hook/permission config ships; keep settings.local.json
# and per-user state ignored.
.claude/*
!.claude/settings.json

# Python
__pycache__/
*.pyc
.venv/
.coverage
*.egg-info/
.hypothesis/

# Build artifacts
build/
arch/*/build/

# DAG signing key
tooling/.dag-key
*.lock

# Working notes (in-progress audits, scratch analyses, drafts).
# Survive across sessions; never committed.
notes/
